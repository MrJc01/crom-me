# Cloudflare Settings
CLOUDFLARE_API_TOKEN=your_token_here
CLOUDFLARE_ZONE_ID=your_zone_id_here

# Database Settings
# Format: postgres://user:password@localhost:5432/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cromme?sslmode=disable

# GitHub OAuth Settings
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
GITHUB_REDIRECT_URL=https://crom.me/auth/callback

# Application Settings
APP_SECRET=a_very_long_and_secure_random_string
PORT=8080
APP_ENV=production

# Notifications
DISCORD_WEBHOOK_URL=your_webhook_url_here

# Tracking Analytics
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
